# Secrets are bind-mounted at runtime, never baked into the image
.env

# Rebuilt inside the image
node_modules
bin

# Editor / OS cruft (.git IS included so the startup commit-log feature works)
.gitignore
.vscode
.idea
.DS_Store
.VSCodeCounter

# Generated at runtime
res/ccg/generated
res/ccg/inventory

# Docs / misc not needed at runtime
README.MD
*.log
