# Copy this file to .env and fill in real values. The .env file is git-ignored.
ENVIRONMENT=dev
DATABASE=dev
SECRET_DEVELOPMENT=false

# Localhost port for the restart-check endpoint (deploy safety gate). Default 8475.
RESTART_CHECK_PORT=8475
# Minutes an unchanged impediment may block an auto-deploy before it's overridden as stagnant. Default 10.
STAGNANT_OVERRIDE_MINUTES=10

DISCORD_SECRET=
DISCORD_APP_ID=

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

MW_PW=

LF_KEY=
